<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>NonNegativeScores</fullName>
    <active>true</active>
    <errorConditionFormula>OR(GoalsFor__c &lt; 0, GoalsAgainst__c &lt; 0)</errorConditionFormula>
    <errorMessage>Goals cannot be negative.</errorMessage>
</ValidationRule>
